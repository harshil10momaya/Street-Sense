# ========================================
# StreetSense — Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=StreetSense
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://streetsense:streetsense_pass@localhost:5432/streetsense_db
DATABASE_SYNC_URL=postgresql://streetsense:streetsense_pass@localhost:5432/streetsense_db

# --- AI Models ---
YOLO_WEIGHTS_PATH=ai/weights/best.pt
MIDAS_MODEL_TYPE=DPT_Large
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# --- Severity Thresholds ---
SEVERITY_LOW_MAX=0.33
SEVERITY_MEDIUM_MAX=0.66

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# --- Geo ---
DEFAULT_LATITUDE=13.0827
DEFAULT_LONGITUDE=80.2707
GEOCODER_USER_AGENT=streetsense-app

# --- Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@streetsense.app

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- JWT (for future auth) ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
