# StreetSense — Local Development Environment
APP_NAME=StreetSense
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

DATABASE_URL=postgresql+asyncpg://streetsense:streetsense_pass@127.0.0.1:5432/streetsense_db?ssl=false
DATABASE_SYNC_URL=postgresql://streetsense:streetsense_pass@127.0.0.1:5432/streetsense_db?sslmode=disable

YOLO_WEIGHTS_PATH=ai/weights/best.pt
MIDAS_MODEL_TYPE=DPT_Large
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

SEVERITY_LOW_MAX=0.33
SEVERITY_MEDIUM_MAX=0.66

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

DEFAULT_LATITUDE=13.0827
DEFAULT_LONGITUDE=80.2707
GEOCODER_USER_AGENT=streetsense-app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@streetsense.app

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

SECRET_KEY=dev-only-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
